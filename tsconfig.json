{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node"
  },
  "include": ["lib/**/*.js", "server.js", "dashboard/**/*.js"],
  "exclude": ["node_modules", "tests", "coverage", "dist"]
}
