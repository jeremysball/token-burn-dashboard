{
  "name": "token-burn-dashboard",
  "version": "0.1.0",
  "description": "Real-time token usage dashboard with cost analysis",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "node build.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "npx playwright test tests/playwright/overflow.spec.js --reporter=list",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "keywords": [
    "dashboard",
    "analytics",
    "tokens",
    "cost-tracking",
    "real-time"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@playwright/test": "^1.58.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "typescript": "^5.9.3"
  }
}
