# Copy to .env and adjust as needed. All variables are optional; sensible
# defaults are used when unset (see lib/config.js).

# --- Server ---
PORT=7071
HOST=127.0.0.1
# Comma-separated list of origins allowed for CORS (empty = no cross-origin access)
ALLOWED_ORIGINS=
# Bearer token required on /api/* requests when set (unset = no auth check)
DASHBOARD_AUTH_TOKEN=
# Root directory git-blame/session discovery is restricted to (defaults to $HOME)
DASHBOARD_PROJECT_ROOT=

# --- AI insights analysis (/api/insights/analyze) ---
# taskferry model used to generate usage insights. Must be a model taskferry
# can dispatch to (see `taskferry doctor` / `dispatching-providers`).
TASKFERRY_INSIGHTS_MODEL=opencode/deepseek-v4-flash-free
# Scratch directory the taskferry worker runs in (isolated from the project root)
DASHBOARD_INSIGHTS_SCRATCH_DIR=

# --- Session discovery ---
# Comma-separated extra directories to scan for session files
EXTRA_SESSION_DIRS=
# Override the root directory scanned for Claude project session files
CLAUDE_PROJECTS_DIR=
# Cap (bytes) on individual session file size before it's skipped
MAX_SESSION_BYTES=104857600

# --- OpenRouter pricing lookup ---
OPENROUTER_MODELS_URL=https://openrouter.ai/api/v1/models
OPENROUTER_REFRESH_MS=21600000
OPENROUTER_TIMEOUT_MS=15000
# Set to 1 to disable the background OpenRouter pricing auto-fetch
OPENROUTER_DISABLE_AUTOFETCH=
